{
  "description": "Token and cost tracking hooks for every Claude Code prompt and response",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_prompt.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_prompt.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/log_response.py\" || python \"${CLAUDE_PLUGIN_ROOT}/scripts/log_response.py\"",
            "async": true
          }
        ]
      }
    ]
  }
}
